# Local dev: leave empty — Vite proxies /api → http://127.0.0.1:8000 (vite.config.ts).
# Vercel production: leave empty — vercel.json proxies /api → Railway.
# Else: set FastAPI origin (no trailing slash).
VITE_API_BASE_URL=

# Optional: public site URL for canonical / OG when not using default (no trailing slash).
# VITE_SITE_URL=https://file-mitra.vercel.app
