# --- API (FastAPI) ---
# Local `npm run dev`: leave empty — Vite proxies /api → http://127.0.0.1:8000 (vite.config.ts).
# Vercel: leave empty if vercel.json proxies /api → Railway.
# Or point the browser straight at your API (no trailing slash):
# VITE_API_BASE_URL=https://your-app.up.railway.app
VITE_API_BASE_URL=

# --- Site URL (SEO: canonical, OG, blog JSON-LD) ---
# Development: .env.development sets http://localhost:5173 (copy from .env.example if needed).
# Production / custom domain (no trailing slash):
# VITE_SITE_URL=https://file-mitra.vercel.app
VITE_SITE_URL=
